<form method="POST" action="/api/productos" enctype="multipart/form-data">
  <div class="mb-3">
    <label for="nombre-producto" class="form-label">Nombre Producto</label>
    <input type="text" class="form-control" id="nombre-producto" name="nombre">
  </div>
  <div class="mb-3">
    <label for="precio-producto" class="form-label">Precio producto</label>
    <input type="number" class="form-control" id="precio-producto" name="precio">
  </div>
  <div class="mb-3">
    <label for="imagen-producto" class="form-label">URL imagen</label>
    <input type="file" class="form-control" id="imagen-producto" name="imagen">
  </div>
  <button type="submit" class="btn btn-primary">Crear producto</button>
</form>